{
  "name": "promptbridge-arabic",
  "version": "0.7.0",
  "description": "Arabic-first prompt translator and optimizer for AI coding agents.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZiadEldesoky/promptbridge-arabic.git"
  },
  "bugs": {
    "url": "https://github.com/ZiadEldesoky/promptbridge-arabic/issues"
  },
  "homepage": "https://github.com/ZiadEldesoky/promptbridge-arabic#readme",
  "bin": {
    "promptbridge": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "docs",
    "extensions",
    "examples",
    "scripts/build-browser-extension.mjs",
    "src",
    "tsconfig.browser.json",
    "tsconfig.json",
    "AGENTS.md",
    "CHANGELOG.md",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "tsc -p tsconfig.json",
    "build:browser": "node scripts/build-browser-extension.mjs",
    "dev": "tsx src/cli.ts",
    "prepack": "npm run build && npm run build:browser",
    "test": "vitest run",
    "typecheck:browser": "tsc -p tsconfig.browser.json",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "arabic",
    "egyptian-arabic",
    "cli",
    "browser-extension",
    "raycast",
    "prompt-engineering",
    "coding-agent",
    "codex",
    "cursor",
    "claude",
    "accessibility",
    "developer-tools"
  ],
  "author": "Ziad Eldesoky",
  "license": "MIT",
  "engines": {
    "node": ">=18.18"
  },
  "dependencies": {
    "clipboardy": "^4.0.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "esbuild": "^0.21.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
