{
  "name": "promptbridge-arabic",
  "version": "0.11.9",
  "description": "Arabic-first prompt translator and optimizer for AI coding agents.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZiadEldesoky/promptbridge-arabic.git"
  },
  "bugs": {
    "url": "https://github.com/ZiadEldesoky/promptbridge-arabic/issues"
  },
  "homepage": "https://github.com/ZiadEldesoky/promptbridge-arabic#readme",
  "bin": {
    "promptbridge": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "docs",
    "extensions/browser",
    "extensions/linux",
    "extensions/macos/Package.swift",
    "extensions/macos/README.md",
    "extensions/macos/Sources",
    "extensions/macos/src",
    "extensions/raycast",
    "extensions/windows",
    "extensions/vscode",
    "examples",
    "scripts/build-browser-extension.mjs",
    "scripts/build-macos-menubar.mjs",
    "scripts/package-browser-extension.mjs",
    "scripts/generate-extension-icons.mjs",
    "scripts/build-vscode-extension.mjs",
    "scripts/package-vscode-extension.mjs",
    "scripts/open-vsx.mjs",
    "src",
    "tsconfig.browser.json",
    "tsconfig.vscode.json",
    "tsconfig.json",
    "AGENTS.md",
    "CHANGELOG.md",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "tsc -p tsconfig.json",
    "build:browser": "node scripts/build-browser-extension.mjs",
    "build:macos": "node scripts/build-macos-menubar.mjs",
    "build:vscode": "node scripts/build-vscode-extension.mjs",
    "assets:icons": "node scripts/generate-extension-icons.mjs",
    "dev": "tsx src/cli.ts",
    "package:browser": "node scripts/package-browser-extension.mjs",
    "package:vscode": "node scripts/package-vscode-extension.mjs",
    "openvsx:verify": "node scripts/open-vsx.mjs verify",
    "openvsx:ensure-namespace": "node scripts/open-vsx.mjs ensure-namespace",
    "openvsx:publish": "node scripts/open-vsx.mjs publish",
    "prepack": "npm run build && npm run build:browser && npm run build:vscode && npm run assets:icons",
    "release:browser": "npm run build:browser && npm run assets:icons && npm run package:browser",
    "release:macos": "npm run build && npm run build:macos",
    "release:vscode": "npm run build:vscode && npm run assets:icons && npm run package:vscode",
    "smoke:cli": "node dist/cli.js --version",
    "test": "vitest run",
    "typecheck:browser": "tsc -p tsconfig.browser.json",
    "typecheck:vscode": "tsc -p tsconfig.vscode.json",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "arabic",
    "egyptian-arabic",
    "cli",
    "browser-extension",
    "raycast",
    "prompt-engineering",
    "coding-agent",
    "codex",
    "cursor",
    "claude",
    "accessibility",
    "developer-tools"
  ],
  "author": "Ziad Eldesoky",
  "license": "MIT",
  "engines": {
    "node": ">=18.18"
  },
  "dependencies": {
    "clipboardy": "^4.0.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.21.5",
    "ovsx": "^1.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
