{
  "manifest_version": 3,
  "name": "PromptBridge Arabic",
  "version": "0.11.4",
  "description": "Convert selected Arabic developer prompts into structured English prompts inside web AI tools.",
  "permissions": ["activeTab", "contextMenus", "scripting", "storage"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "dist/background.js"
  },
  "action": {
    "default_title": "PromptBridge Arabic",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "commands": {
    "replace-selection": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Convert selected Arabic prompt text"
    }
  },
  "minimum_chrome_version": "114"
}
